{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/site-header-v2",
  "version": "1.0.0",
  "title": "Site Header V2",
  "category": "ai-zippy",
  "icon": "menu",
  "description": "Boutique responsive site header with centered navigation, utility icons, cart, and pill CTA.",
  "keywords": [
    "header",
    "navigation",
    "menu",
    "shop"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "logoId": {
      "type": "number",
      "default": 0
    },
    "logoUrl": {
      "type": "string",
      "default": ""
    },
    "logoAlt": {
      "type": "string",
      "default": "Tom & Stefanie"
    },
    "brandText": {
      "type": "string",
      "default": "Tom & Stefanie"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#fbf7ef"
    },
    "buttonColor": {
      "type": "string",
      "default": "#ff6c73"
    },
    "buttonHoverColor": {
      "type": "string",
      "default": "#ee5961"
    },
    "badgeColor": {
      "type": "string",
      "default": "#ff6c73"
    },
    "actionIconColor": {
      "type": "string",
      "default": "#070707"
    },
    "actionIconHoverColor": {
      "type": "string",
      "default": "#ff6c73"
    },
    "menuId": {
      "type": "number",
      "default": 0
    },
    "shopLabel": {
      "type": "string",
      "default": "Shop"
    },
    "shopUrl": {
      "type": "string",
      "default": "/shop"
    },
    "giftLabel": {
      "type": "string",
      "default": "Gift"
    },
    "giftUrl": {
      "type": "string",
      "default": "/gift"
    },
    "bestsellersLabel": {
      "type": "string",
      "default": "Bestsellers"
    },
    "bestsellersUrl": {
      "type": "string",
      "default": "/bestsellers"
    },
    "saleLabel": {
      "type": "string",
      "default": "Sale"
    },
    "saleUrl": {
      "type": "string",
      "default": "/sale"
    },
    "corporateLabel": {
      "type": "string",
      "default": "Corporate/Wholesale"
    },
    "corporateUrl": {
      "type": "string",
      "default": "/corporate-wholesale"
    },
    "storyLabel": {
      "type": "string",
      "default": "Our Story"
    },
    "storyUrl": {
      "type": "string",
      "default": "/our-story"
    },
    "buttonText": {
      "type": "string",
      "default": "Shop Now"
    },
    "buttonUrl": {
      "type": "string",
      "default": "/shop"
    },
    "showSearch": {
      "type": "boolean",
      "default": true
    },
    "searchUrl": {
      "type": "string",
      "default": "/?s="
    },
    "searchIconId": {
      "type": "number",
      "default": 0
    },
    "searchIconUrl": {
      "type": "string",
      "default": ""
    },
    "searchIconAlt": {
      "type": "string",
      "default": "Search"
    },
    "showWishlist": {
      "type": "boolean",
      "default": true
    },
    "wishlistUrl": {
      "type": "string",
      "default": "/wishlist"
    },
    "wishlistIconId": {
      "type": "number",
      "default": 0
    },
    "wishlistIconUrl": {
      "type": "string",
      "default": ""
    },
    "wishlistIconAlt": {
      "type": "string",
      "default": "Wishlist"
    },
    "showMiniCart": {
      "type": "boolean",
      "default": true
    },
    "cartUrl": {
      "type": "string",
      "default": "/cart"
    },
    "cartIconId": {
      "type": "number",
      "default": 0
    },
    "cartIconUrl": {
      "type": "string",
      "default": ""
    },
    "cartIconAlt": {
      "type": "string",
      "default": "Cart"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}